config.json.pre-merge-*.bak
config.json.*.bak

# Runtime state — printer telemetry, cloud auth tokens, user notes,
# user-saved scene files. None of this should be in git.
data/
!data/.gitkeep

# Legacy locations (cleaned up by migrator on first boot)
accessToken.json
note.json
public/data.json
public/data_*.json

